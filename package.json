{
  "name": "prod-express-template",
  "version": "1.0.0",
  "description": "An Express.js production ready template with typescript, ESLint and Prettier configured",
  "main": "index.js",
  "type": "module",
  "imports": {
    "#modules/*": "./dist/modules/*",
    "#db/*": "./dist/db/*",
    "#shared/*": "./dist/shared/*",
    "#utils/*": "./dist/utils/*",
    "#middleware/*": "./dist/middleware/*",
    "#lib/*": "./dist/lib/*"
  },
  "scripts": {
    "dev": "tsx --watch --env-file .env src/index.ts",
    "dev:staging": "tsx --watch --env-file .env.staging src/index.ts",
    "dev:prod": "tsx --watch --env-file .env.production src/index.ts",
    "start": "node --env-file .env dist/index.js",
    "build": "tsc",
    "type-check": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest",
    "test:run": "vitest --run",
    "test:ui": "vitest --ui",
    "coverage": "vitest run --coverage",
    "prepare": "husky",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx --env-file .env src/db/migrate.ts",
    "db:update": "npm run db:generate && npm run db:migrate"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint",
      "prettier --check"
    ],
    "*.{json,yml,yaml,md}": [
      "prettier --check"
    ]
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/GiftBanda/prod-express-template.git"
  },
  "keywords": [],
  "author": "Gift Banda",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/GiftBanda/prod-express-template/issues"
  },
  "homepage": "https://github.com/GiftBanda/prod-express-template#readme",
  "dependencies": {
    "@paralleldrive/cuid2": "^3.3.0",
    "@types/redis": "^4.0.10",
    "bcrypt": "^6.0.0",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "dotenv-expand": "^13.0.0",
    "drizzle-orm": "^0.45.2",
    "drizzle-zod": "^0.8.3",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "express-validator": "^7.3.2",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "nodemailer": "^8.0.10",
    "pg": "^8.20.0",
    "rate-limit-redis": "^5.0.0",
    "redis": "^5.12.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tsconfig/node22": "^22.0.5",
    "@types/bcrypt": "^6.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.7.0",
    "@types/nodemailer": "^8.0.0",
    "@types/pg": "^8.20.0",
    "@vitest/coverage-v8": "^4.1.5",
    "@vitest/eslint-plugin": "^1.6.16",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.3.0",
    "eslint-plugin-perfectionist": "^5.9.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.2",
    "vitest": "^4.1.8"
  }
}
